      "seed": 888120039,
      "version": 361,
      "versionNonce": 584128713,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772289497628,
      "link": null,
      "locked": false,
      "text": "for(left -> right)\n    arr[top][left++]\ntop++\n\nfor(top -> bottom)\n    arr[top++][right]\nright --\n\nfor(right -> left)\n    arr[bottom][right--]\nbottom++\n\nfor(bottom -> top)\n    arr[bottom--][left]\nleft++\n    ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "for(left -> right)\n    arr[top][left++]\ntop++\n\nfor(top -> bottom)\n    arr[top++][right]\nright --\n\nfor(right -> left)\n    arr[bottom][right--]\nbottom++\n\nfor(bottom -> top)\n    arr[bottom--][left]\nleft++\n    ",
      "autoResize": true,
      "lineHeight": 1.25
    },
