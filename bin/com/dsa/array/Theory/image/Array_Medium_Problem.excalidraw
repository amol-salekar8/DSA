      "isDeleted": false,
      "boundElements": null,
      "updated": 1772303563805,
      "link": null,
      "locked": false,
      "text": "n : The total number of items in the set.\nr : The number of items to be chosen.\n! : Factorial symbol (e.g., 4! = 4 * 3 * 2 * 1).",
      "fontSize": 11.223494786233823,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "n : The total number of items in the set.\nr : The number of items to be chosen.\n! : Factorial symbol (e.g., 4! = 4 * 3 * 2 * 1).",
