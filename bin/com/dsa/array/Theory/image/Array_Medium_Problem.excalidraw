      "text": "Rotate matrix by 90 degrees",
      "fontSize": 25.45729068311489,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Rotate matrix by 90 degrees",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "I4Mx5nXqNorcqXX-eErpd",
      "type": "text",
      "x": 657.5389492568689,
      "y": 17.39438677799916,
      "width": 308.5716393909302,
      "height": 115.7531062258529,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6B",
      "roundness": null,
      "seed": 1666065031,
      "version": 235,
      "versionNonce": 800797339,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772685860544,
      "link": null,
      "locked": false,
      "text": "Approach 1: \n// Perform rotation logic\n        for (int i = 0; i < n; i++) {\n            for (int j = 0; j < n; j++) {\n                rotated[j][n - i - 1] = matrix[i][j];\n            }\n        }",
      "fontSize": 13.228926425811762,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Approach 1: \n// Perform rotation logic\n        for (int i = 0; i < n; i++) {\n            for (int j = 0; j < n; j++) {\n                rotated[j][n - i - 1] = matrix[i][j];\n            }\n        }",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "J-xLeNF9kScyODLMFaqFy",
      "type": "text",
      "x": 1006.8271526605918,
      "y": 13.573114299007415,
      "width": 188.52659866203118,
      "height": 124.72193058288809,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6N",
      "roundness": null,
      "seed": 876247527,
      "version": 325,
      "versionNonce": 1284515643,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772685860544,
      "link": null,
      "locked": false,
      "text": "Approach 2:\n// Transpose the matrix\n        for (int i = 0; i < n; i++) {\n            for (int j = 0; j < i; j++) {\n                \n                // Swap elements across the diagonal\n                int temp = matrix[i][j];\n                matrix[i][j] = matrix[j][i];\n                matrix[j][i] = temp;\n                \n            }\n        }\n",
      "fontSize": 7.675195728177728,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Approach 2:\n// Transpose the matrix\n        for (int i = 0; i < n; i++) {\n            for (int j = 0; j < i; j++) {\n                \n                // Swap elements across the diagonal\n                int temp = matrix[i][j];\n                matrix[i][j] = matrix[j][i];\n                matrix[j][i] = temp;\n                \n            }\n        }\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
