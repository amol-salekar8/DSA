      "link": null,
      "locked": false,
      "text": "Kadane's Algorithm",
      "fontSize": 62.00406651868987,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Kadane's Algorithm",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "HB6wXj0rF3nWYCiD1WwJs",
      "type": "text",
      "x": 2592.7411901653486,
      "y": 21.111839616402563,
      "width": 439.3997802734375,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b8x",
      "roundness": null,
      "seed": 545725199,
      "version": 45,
      "versionNonce": 1561400193,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772847649714,
      "link": null,
      "locked": false,
      "text": "int maxiMum = Integer.MIN_VALUE;\n        /* Current Sum */\n        int sum = 0;\n        for (int i = 0; i < nums.length; i++) {\n            sum += nums[i];\n            maxiMum = Math.max(maxiMum,sum);\n            /* Reset Sum */\n            if(sum < 0) sum = 0;\n        }\n        return maxiMum;",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "int maxiMum = Integer.MIN_VALUE;\n        /* Current Sum */\n        int sum = 0;\n        for (int i = 0; i < nums.length; i++) {\n            sum += nums[i];\n            maxiMum = Math.max(maxiMum,sum);\n            /* Reset Sum */\n            if(sum < 0) sum = 0;\n        }\n        return maxiMum;",
      "autoResize": true,
      "lineHeight": 1.25
    },
