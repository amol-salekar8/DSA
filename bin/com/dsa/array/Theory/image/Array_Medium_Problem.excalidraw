    {
      "id": "rrwBTLxHgfmpUgH1svXzw",
      "type": "text",
      "x": 2291.997728480982,
      "y": -532.7876596373219,
      "width": 232.6998291015625,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
