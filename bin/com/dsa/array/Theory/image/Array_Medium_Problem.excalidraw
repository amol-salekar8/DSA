    {
      "id": "F71rsx1VrLi-jKD9efstB",
      "type": "text",
      "x": 538.5000610351562,
      "y": -329.50006103515625,
      "width": 1007.0193481445312,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
